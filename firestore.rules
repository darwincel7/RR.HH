rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Email is compared in both stored casings because Firestore rules cannot lowercase.
    // Role-based admin (roleIds) is the primary, robust path.
    function isAdminEmail() {
      return isAuthenticated() &&
        (request.auth.token.email == "daruingmejia@gmail.com" ||
         request.auth.token.email == "Daruingmejia@gmail.com");
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleIds.hasAny(['admin']) ||
        isAdminEmail());
    }

    function isRecruiter() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleIds.hasAny(['recruiter', 'admin']) ||
        isAdminEmail());
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isRecruiter());
      // A new sign-in may only create its OWN doc with NO roles (pending). Granting
      // 'recruiter'/'admin' requires an existing admin (approval from Settings).
      allow create: if isAuthenticated() && ((isOwner(userId) && request.resource.data.roleIds == []) || isAdmin());
      // Owners may edit their own profile but never their own roleIds; only an admin
      // can change roles (approve / revoke access).
      allow update: if isAuthenticated() && ((isOwner(userId) && request.resource.data.roleIds == resource.data.roleIds) || isAdmin());
      allow delete: if isAdmin();
    }

    match /vacancies/{vacancyId} {
      allow read: if true; // Public can read active vacancies (careers portal)
      allow create, update, delete: if isRecruiter();
    }

    match /candidates/{candidateId} {
      allow read: if isRecruiter() || isOwner(candidateId);
      allow create: if isAuthenticated(); // Anonymous applicants create their profile
      allow update: if isRecruiter() || isOwner(candidateId);
    }

    match /applications/{applicationId} {
      // A candidate opens their OWN evaluation/test link by its unguessable
      // {anonUID}_{vacancyId} document id (capability URL) — a single-document GET.
      // LIST is recruiter-only, so the whole collection can never be enumerated or
      // dumped (previously `read: if true` let anyone download every applicant's
      // PII, CV links, answers, scores and private interview notes).
      allow get: if true;
      allow list: if isRecruiter();
      // Recruiters (e.g. bulk upload) may create freely. A public applicant may only
      // create a fresh 'Nuevo' application and CANNOT preset any evaluation field
      // (no injecting a fake top-ranked candidate).
      allow create: if isRecruiter() ||
        (isAuthenticated()
          && request.resource.data.stage == 'Nuevo'
          && !request.resource.data.keys().hasAny(['stage2Scoring', 'testResults', 'scoreSummary', 'recommendation', 'interviewScorecard']));
      // Scores/answers are now written ONLY server-side (Admin SDK, which bypasses
      // rules) or by a recruiter. Candidates can no longer forge their own scores.
      allow update: if isRecruiter();
      allow delete: if isRecruiter();
    }

    match /whatsapp_messages/{messageId} {
      allow read: if isRecruiter();
      // Inbound messages are now written by the server via the Admin SDK (which
      // bypasses these rules), so no unauthenticated client write is needed.
      allow create: if isRecruiter();
      allow update, delete: if false; // Messages are immutable
    }

    // WhatsApp session credentials. These are read/written ONLY by the server via
    // the Firebase Admin SDK, which bypasses security rules. No client may touch them.
    // (Closing these is the whole point of the Admin SDK migration — they used to be
    // world read/write, which let anyone hijack the company WhatsApp session.)
    match /whatsapp_auth_session_secret_8f73b2a1/{docId} {
      allow read, write: if false;
    }
    match /whatsapp_auth_session_v2/{docId} {
      allow read, write: if false;
    }
    match /whatsapp_auth_dev/{docId} {
      allow read, write: if false;
    }
    match /whatsapp_auth_prod/{docId} {
      allow read, write: if false;
    }

    match /settings/{document} {
      allow read: if true; // Public can read settings (form questions, company branding)
      allow write: if isRecruiter(); // Only recruiters/admins can modify
    }

    match /interview_sessions/{sessionId} {
      allow read, write: if isRecruiter();
    }

    match /interview_participants/{participantId} {
      allow read, write: if isRecruiter();
    }
  }
}
